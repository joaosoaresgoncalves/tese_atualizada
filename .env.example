# Copy this file to `.env` and fill in the values to run the pipeline on the
# sample (scripts/run_pipeline.py, scripts/run_sweep.py). The figure notebook
# needs none of this — it is fully offline.

# ── Primary model: Azure OpenAI (gpt-5.4-mini in the dissertation) ──
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Data folder ──
# Folder of PO baselines / ASN XML. Defaults to the bundled sample_data/.
ASN_DATA_DIR=

# ── Optional: second model for the cross-model replication ──
# An OpenAI-compatible endpoint (e.g. Mistral-Large-3 on Azure AI Foundry).
# Set LLM_BACKEND=openai_compat to use these instead of Azure OpenAI.
LLM_BACKEND=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_SUPPORTS_SEED=
LLM_SUPPORTS_JSON_SCHEMA=

# ── Optional behaviour flags (sensible defaults are built in) ──
# DISABLE_R18=false              # skip the stateful duplicate-detection rule
# USE_STAGE5_FEW_SHOT=true       # include worked examples in the validation prompt
# USE_SUPPLIER_PROFILES=true     # inject supplier history (RQ3 ablation)
